# Replace <domain> and /var/www/tariffcalc-bitrix24 with real VPS values.
# Install this file as /etc/nginx/sites-available/tariffcalc and symlink it to sites-enabled.
# Certbot can add the final listen 443 / ssl_certificate directives:
# sudo certbot --nginx -d calc.<domain> -d api.calc.<domain>

server {
    listen 80;
    listen [::]:80;
    server_name calc.<domain>;

    root /var/www/tariffcalc-bitrix24/apps/web/dist;
    index index.html;

    access_log /var/log/nginx/tariffcalc-web.access.log;
    error_log /var/log/nginx/tariffcalc-web.error.log;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(?:js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.calc.<domain>;

    client_max_body_size 20M;

    access_log /var/log/nginx/tariffcalc-api.access.log;
    error_log /var/log/nginx/tariffcalc-api.error.log;

    location /health {
        proxy_pass http://127.0.0.1:9099/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:9099;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
